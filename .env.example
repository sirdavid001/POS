# Database
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5432/pos_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Merchant subscription billing
# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PLAN_MONTHLY=PLN_xxxxxxxxx
PAYSTACK_PLAN_QUARTERLY=PLN_xxxxxxxxx
PAYSTACK_PLAN_YEARLY=PLN_xxxxxxxxx

# Flutterwave
# Generate a new secret key in Flutterwave. Never reuse a key shared in chat.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxx-X
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxx-X
FLUTTERWAVE_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
FLUTTERWAVE_PLAN_MONTHLY=00000
FLUTTERWAVE_PLAN_QUARTERLY=00000
FLUTTERWAVE_PLAN_YEARLY=00000

# Billing
BILLING_RETURN_URL=https://quickpos.name.ng/account#billing
CRON_SECRET=replace-with-a-random-cron-secret
# Optional multi-currency checkout. NGN is always the fallback.
# Only add currencies your active Paystack/Flutterwave account can accept.
PAYSTACK_SUPPORTED_CURRENCIES=NGN,USD,GHS,ZAR,KES,XOF
FLUTTERWAVE_SUPPORTED_CURRENCIES=NGN,USD,GBP,EUR,GHS,KES,ZAR,XOF,UGX,TZS,RWF,ZMW,XAF,CAD,EGP
# Prices use major units. If a currency/plan is missing, checkout falls back to NGN.
BILLING_CURRENCY_PRICES={}
# Example:
# BILLING_CURRENCY_PRICES={"USD":{"activation_5m":15,"monthly":4,"quarterly":10,"yearly":38},"GHS":{"activation_5m":150,"monthly":38,"quarterly":102,"yearly":375}}
# Recurring non-NGN plans need provider-specific recurring plan IDs.
PAYSTACK_PLAN_MONTHLY_USD=
PAYSTACK_PLAN_QUARTERLY_USD=
PAYSTACK_PLAN_YEARLY_USD=
FLUTTERWAVE_PLAN_MONTHLY_USD=
FLUTTERWAVE_PLAN_QUARTERLY_USD=
FLUTTERWAVE_PLAN_YEARLY_USD=

# Download release manifest used by the authenticated website account portal
DOWNLOADS_MANIFEST_URL=https://downloads.quickpos.name.ng/latest.json
GITHUB_LATEST_RELEASE_URL=https://api.github.com/repos/sirdavid001/POS/releases/latest
IOS_WEB_APP_URL=https://quickposs.vercel.app

# Store sales statement email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=QuickPOS <billing@quickpos.name.ng>
EMAIL_REPLY_TO=support@quickpos.name.ng

# Password recovery
PASSWORD_RESET_URL=https://quickpos.name.ng/account#reset-password
PASSWORD_RESET_EXPIRY_MINUTES=30

# Optional local/demo seed account. Never set public credentials in source control.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Frontend
# Both the website account portal and every POS app build must use this same API.
# Local development may keep localhost; production should use the deployed server.
VITE_API_URL=http://localhost:3001/api/v1
VITE_WS_URL=ws://localhost:3001
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
VITE_RELEASE_MANIFEST_URL=https://downloads.quickpos.name.ng/latest.json
