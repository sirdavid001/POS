{
  "name": "pos-system",
  "version": "1.0.0",
  "private": true,
  "main": "desktop/main.cjs",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client",
    "packages/website"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w packages/server",
    "db:seed": "npm run db:seed -w packages/server",
    "billing:configure": "node scripts/configure-billing-providers.mjs",
    "mobile:sync": "npm run build -w packages/client && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "desktop:start": "npm run build -w packages/client && electron .",
    "desktop:win": "npm run build -w packages/client && electron-builder --win nsis --x64",
    "desktop:mac": "npm run build -w packages/client && electron-builder --mac dmg",
    "desktop:linux": "npm run build -w packages/client && electron-builder --linux AppImage deb --x64",
    "website:dev": "npm run dev -w packages/website",
    "website:build": "npm run build -w packages/website"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "app.quickpos.desktop",
    "productName": "QuickPOS",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "desktop/**/*",
      "packages/client/dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/quickpos.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "QuickPOS-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "build/quickpos.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "QuickPOS-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/quickpos.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "QuickPOS-${version}-${arch}.${ext}",
      "category": "Office"
    },
    "publish": {
      "provider": "generic",
      "url": "https://downloads.quickpos.name.ng/desktop/windows"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
